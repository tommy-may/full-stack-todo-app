{
  "name": "@backend/server",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/db/validator.ts",
    "./types": {
      "types": "./src/app.ts"
    }
  },
  "scripts": {
    "start:dev:db": "docker-compose --env-file .env.development -f docker-compose.development.yml up -d",
    "start:dev": "bun run --hot src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run --env-file .env.development drizzle-kit migrate",
    "db:studio": "bun run --env-file .env.development drizzle-kit studio",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.9",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint-config/recommended": "workspace:*",
    "@prettier-config/recommended": "workspace:*",
    "@tsconfig/recommended": "workspace:*",
    "@types/bun": "latest",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.1.0",
    "eslint-plugin-drizzle": "^0.2.3",
    "pino-pretty": "^13.1.3"
  }
}
